  "questions": [
    {
      "id": "q1",
      "number": 1,
      "text": "Меня легко перегружают сильные сенсорные стимулы (громкие звуки, яркий свет, резкие запахи).",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q2",
      "number": 2,
      "text": "Кажется, я замечаю тонкие нюансы в окружающей обстановке.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q3",
      "number": 3,
      "text": "На меня влияет настроение других людей.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q4",
      "number": 4,
      "text": "Я склонен(на) более остро чувствовать боль.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q5",
      "number": 5,
      "text": "В насыщенные событиями дни я чувствую потребность уединиться в кровати или в тёмной комнате, чтобы побыть в тишине.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q6",
      "number": 6,
      "text": "Я особенно чувствителен(на) к воздействию кофеина.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q7",
      "number": 7,
      "text": "Меня легко выводят из равновесия яркий свет, резкие запахи, грубые ткани или сирены рядом.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q8",
      "number": 8,
      "text": "У меня богатая, сложная внутренняя жизнь.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q9",
      "number": 9,
      "text": "Мне неприятны громкие звуки.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q10",
      "number": 10,
      "text": "Меня глубоко трогает искусство или музыка.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q11",
      "number": 11,
      "text": "Моя нервная система иногда чувствует себя настолько истощённой, что мне нужно побыть одному(ой).",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q12",
      "number": 12,
      "text": "Я добросовестный(ая) (скрупулёзный(ая), ответственный(ая)).",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q13",
      "number": 13,
      "text": "Я легко пугаюсь.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q14",
      "number": 14,
      "text": "Я нервничаю, когда нужно сделать много дел за короткое время.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q15",
      "number": 15,
      "text": "Когда люди чувствуют дискомфорт в физической обстановке, я обычно знаю, что нужно сделать, чтобы им стало комфортнее (например, изменить освещение или рассадку).",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q16",
      "number": 16,
      "text": "Меня раздражает, когда люди пытаются заставить меня делать слишком много дел одновременно.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q17",
      "number": 17,
      "text": "Я стараюсь избегать ошибок и забывчивости.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q18",
      "number": 18,
      "text": "Я сознательно избегаю жестоких фильмов и телепередач.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q19",
      "number": 19,
      "text": "Когда вокруг меня происходит слишком много всего, я испытываю неприятное возбуждение (стресс).",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q20",
      "number": 20,
      "text": "Сильный голод вызывает у меня сильную реакцию — нарушает концентрацию или портит настроение.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q21",
      "number": 21,
      "text": "Перемены в жизни выбивают меня из колеи.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q22",
      "number": 22,
      "text": "Я замечаю и наслаждаюсь тонкими, изысканными ароматами, вкусами, звуками, произведениями искусства.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q23",
      "number": 23,
      "text": "Мне неприятно, когда происходит слишком много всего одновременно.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q24",
      "number": 24,
      "text": "Я делаю приоритетом организацию своей жизни так, чтобы избегать расстраивающих или перегружающих ситуаций.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q25",
      "number": 25,
      "text": "Меня беспокоят интенсивные стимулы — громкий шум или хаотичные сцены.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q26",
      "number": 26,
      "text": "Когда мне нужно соревноваться или выполнять задание под наблюдением, я так нервничаю или трясусь, что делаю это намного хуже, чем обычно.",
      "trait": "sensitivity",
      "reverse": false
    },
    {
      "id": "q27",
      "number": 27,
      "text": "В детстве родители или учителя считали меня чувствительным(ой) или застенчивым(ой).",
      "trait": "sensitivity",
      "reverse": false
    }
  ],
